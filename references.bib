@article{coteCasualResistanceLongitudinal2020,
  title = {Casual {{Resistance}}: {{A Longitudinal Case Study}} of {{Video Gaming}}'s {{Gendered Construction}} and {{Related Audience Perceptions}}.},
  shorttitle = {Casual {{Resistance}}},
  author = {Cote, Amanda C},
  year = 2020,
  month = dec,
  journal = {Journal of Communication},
  volume = {70},
  number = {6},
  pages = {819--841},
  publisher = {Oxford University Press / USA},
  issn = {0021-9916},
  doi = {10.1093/joc/jqaa028},
  urldate = {2026-02-09},
  abstract = {Many media are associated with masculinity or femininity and male or female audiences, which links them to broader power structures around gender. Media scholars thus must understand how gendered constructions develop and change, and what they mean for audiences. This article addresses these questions through longitudinal, in-depth interviews with female video gamers (2012--2018), conducted as the rise of casual video games potentially started redefining gaming's historical masculinization. The analysis shows that participants have negotiated relationships with casualness. While many celebrate casual games' potential for welcoming new audiences, others resist casual's influence to safeguard their self-identification as gamers. These results highlight how a medium's gendered construction may not be salient to consumers, who carefully navigate divides between their own and industrially designed identities, but can simultaneously reaffirm existing power structures. Further, how participants' views change over time emphasizes communication's ongoing need for longitudinal audience studies that address questions of media, identity, and inclusion.},
  langid = {english},
  keywords = {Society and Gender},
  file = {C:\Users\gerri\Zotero\storage\MNPHXDXI\Cote - 2020 - Casual Resistance A Longitudinal Case Study of Video Gaming's Gendered Construction and Related Aud.pdf}
}

@article{fangConstructingGenderResearch2025a,
  title = {Constructing Gender: Research on Gender Performativity among Video Game Players.},
  shorttitle = {Constructing Gender},
  author = {Fang, Lanyan},
  year = 2025,
  month = mar,
  journal = {Journal of Gender Studies},
  pages = {1--13},
  publisher = {Taylor \& Francis Ltd},
  issn = {0958-9236},
  doi = {10.1080/09589236.2025.2474664},
  urldate = {2026-04-29},
  abstract = {China has become the largest gaming market globally, yet the positioning of gamers of different genders, as well as the dynamics of gender relationships within video games, remain topics vastly underexplored. Existing gender perspectives in gaming research often revolve around character design and gender discrimination, with limited attention given to the micro-level media practices of players based on gender identity. Drawing on Butler's theories of gender norms and gender performativity, this study takes `Honor of Kings' as a case study. Through in-depth interviews with 19 game players, the research reveals that players engage in a unique process of `constructing gender' in their gaming practices. Female players adopt strategies of gender neutralization, gender-switching behaviours, invoking femininity, and building connections to create a better gaming experience and environment for themselves. On the other hand, male players' gender performativity is primarily manifested through the use of gender-switching strategies for personal benefits and relaxation. The gender performativity of female players exhibits significant characteristics of avoidance, reflexivity and creativity, which reflects their efforts to fight for gender equality. The players' gender performativity highlights a profound interaction between gender and gaming practices, contributing meaningful insights to gender theories in virtual spaces.},
  langid = {english},
  keywords = {Gameplay/Mechanics,Gender Performativity Theory,Society and Gender},
  file = {C:\Users\gerri\Zotero\storage\T9KJRLT6\Fang - 2025 - Constructing gender research on gender performativity among video game players..pdf}
}

